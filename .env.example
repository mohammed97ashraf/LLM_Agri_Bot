# =============================================================================
# LLM Agri Bot — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# --- LLM (Groq) ---
# Get your API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=openai/gpt-oss-120b
LLM_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# --- Speech-to-Text (Groq Whisper) ---
STT_MODEL=whisper-large-v3-turbo

# --- Text-to-Speech (Groq Orpheus) ---
TTS_MODEL=canopylabs/orpheus-v1-english
TTS_VOICE=autumn

# --- Redis (Conversation Memory) ---
# If not configured, falls back to in-memory storage (lost on restart)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_USERNAME=default
# REDIS_PASSWORD=
REDIS_SSL=false
REDIS_SESSION_TTL=3600

# --- Flask ---
FLASK_SECRET_KEY=change-this-to-a-random-string
FLASK_DEBUG=true
LOG_LEVEL=INFO

# --- Render (auto-set by Render) ---
# PORT=10000
# SITE_URL=https://llm-agri-bot.onrender.com
